@model ProjectViewModel
@{ ViewData["Title"] = "Proje Düzenle"; var users = ViewBag.Users as List<AppUser>; }

<div style="max-width:480px">
  <div class="section-header">
    <h2>Proje Düzenle</h2>
    <a class="btn-outline" href="/Projeler">Geri Dön</a>
  </div>

  <div class="card">
    <form asp-action="Duzenle" asp-route-id="@Model.Id" method="post">
      @Html.AntiForgeryToken()
      <div class="f-group">
        <label class="f-label">Proje Adı</label>
        <input asp-for="Ad" class="f-input" />
      </div>
      <div class="f-group">
        <label class="f-label">Açıklama</label>
        <textarea asp-for="Aciklama" class="f-input"></textarea>
      </div>
      <div class="f-group">
        <label class="f-label">Durum</label>
        <select asp-for="Durum" class="f-input">
          <option value="aktif">Aktif</option>
          <option value="beklemede">Beklemede</option>
          <option value="tamamlandi">Tamamlandı</option>
          <option value="iptal">İptal</option>
        </select>
      </div>
      <div class="g2">
        <div class="f-group">
          <label class="f-label">Başlangıç Tarihi</label>
          <input asp-for="BaslangicTarihi" class="f-input" type="date" />
        </div>
        <div class="f-group">
          <label class="f-label">Bitiş Tarihi</label>
          <input asp-for="BitisTarihi" class="f-input" type="date" />
        </div>
      </div>
      <div class="f-group">
        <label class="f-label">Proje Yöneticisi</label>
        <select asp-for="YoneticiId" class="f-input">
          @if (users != null)
          {
            @foreach (var u in users)
            {
              <option value="@u.Id" selected="@(u.Id == Model.YoneticiId)">@u.FullName</option>
            }
          }
        </select>
      </div>
      <button type="submit" class="btn-primary">Güncelle</button>
    </form>
  </div>
</div>
