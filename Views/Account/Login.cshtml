@model LoginViewModel
@{ Layout = "_Layout"; ViewData["Title"] = "Giriş"; }

<div class="login-page">
  <div class="login-box">
    <div class="login-title" style="color:#2dd4bf;letter-spacing:.15em">ADSATEK</div>
    <div class="login-sub">Teknik ve Biyomedikal Çözümler</div>
    <div class="divider"></div>

    <div asp-validation-summary="All" class="error-msg"></div>

    <form asp-action="Login" method="post">
      @Html.AntiForgeryToken()
      <div class="f-group">
        <label class="f-label">E-Posta</label>
        <input asp-for="Email" class="f-input" placeholder="ornek@sirket.com" autocomplete="email" />
      </div>
      <div class="f-group">
        <label class="f-label">Şifre</label>
        <input asp-for="Password" class="f-input" placeholder="********" autocomplete="current-password" />
      </div>
      <button type="submit" class="btn-primary" style="width:100%;margin-top:8px">Giriş Yap</button>
    </form>
  </div>
</div>
