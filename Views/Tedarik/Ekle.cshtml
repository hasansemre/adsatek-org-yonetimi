@model OrgYonetimi.ViewModels.TedarikViewModel
@{
  ViewData["Title"] = "Yeni Tedarik";
  var stokKartlari = ViewBag.StokKartlari as List<OrgYonetimi.Models.StokKarti>;
  var tedarikFirmalar = ViewBag.TedarikFirmalar as List<OrgYonetimi.Models.Firma>;
  var temsilciFirmalar = ViewBag.TemsilciFirmalar as List<OrgYonetimi.Models.Firma>;
  var projeler = ViewBag.Projeler as List<OrgYonetimi.Models.Project>;
}

<div class="section-header">
  <div>
    <h2>Yeni Tedarik</h2>
    <div class="section-sub">Ürün veya hizmet tedarik kaydı oluşturun</div>
  </div>
  <a class="btn-outline" href="/Tedarik">← Geri Dön</a>
</div>

<div class="card" style="max-width:800px">
  <form method="post" asp-action="Ekle">
    @Html.AntiForgeryToken()

    <div class="f-group">
      <label class="f-label">Ürün/Hizmet *</label>
      <select class="f-input" asp-for="StokKartiId">
        <option value="">-- Seçiniz --</option>
        @if (stokKartlari != null)
        {
          @foreach (var s in stokKartlari)
          {
            <option value="@s.Id">@s.Ad (@(s.Tip == "urun" ? "Ürün" : "Hizmet") - @s.Birim)</option>
          }
        }
      </select>
      <span asp-validation-for="StokKartiId" style="color:var(--red);font-size:0.85rem"></span>
    </div>

    <div class="f-group">
      <label class="f-label">Proje</label>
      <select class="f-input" asp-for="ProjectId">
        <option value="">-- Proje Seçiniz (Opsiyonel) --</option>
        @if (projeler != null)
        {
          @foreach (var p in projeler)
          {
            <option value="@p.Id">@p.Ad</option>
          }
        }
      </select>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
      <div class="f-group">
        <label class="f-label">Tedarikçi Firma *</label>
        <select class="f-input" asp-for="TedarikFirmaId">
          <option value="">-- Seçiniz --</option>
          @if (tedarikFirmalar != null)
          {
            var tedTedarikci = tedarikFirmalar.Where(f => f.Tip == "tedarikci").ToList();
            var tedTemsilci = tedarikFirmalar.Where(f => f.Tip == "temsilci").ToList();
            if (tedTedarikci.Any())
            {
              <optgroup label="Tedarikçi Firmalar">
                @foreach (var f in tedTedarikci)
                {
                  <option value="@f.Id">@f.Ad</option>
                }
              </optgroup>
            }
            if (tedTemsilci.Any())
            {
              <optgroup label="Temsilci Firmalar">
                @foreach (var f in tedTemsilci)
                {
                  <option value="@f.Id">@f.Ad</option>
                }
              </optgroup>
            }
          }
        </select>
        <span asp-validation-for="TedarikFirmaId" style="color:var(--red);font-size:0.85rem"></span>
      </div>
      <div class="f-group">
        <label class="f-label">Temsilci Firma</label>
        <select class="f-input" asp-for="TemsilciFirmaId">
          <option value="">-- Seçiniz (Opsiyonel) --</option>
          @if (temsilciFirmalar != null)
          {
            var temTedarikci = temsilciFirmalar.Where(f => f.Tip == "tedarikci").ToList();
            var temTemsilci = temsilciFirmalar.Where(f => f.Tip == "temsilci").ToList();
            if (temTemsilci.Any())
            {
              <optgroup label="Temsilci Firmalar">
                @foreach (var f in temTemsilci)
                {
                  <option value="@f.Id">@f.Ad</option>
                }
              </optgroup>
            }
            if (temTedarikci.Any())
            {
              <optgroup label="Tedarikçi Firmalar">
                @foreach (var f in temTedarikci)
                {
                  <option value="@f.Id">@f.Ad</option>
                }
              </optgroup>
            }
          }
        </select>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem">
      <div class="f-group">
        <label class="f-label">Miktar *</label>
        <input class="f-input" asp-for="Miktar" type="number" step="1" min="1" />
      </div>
      <div class="f-group">
        <label class="f-label">Birim</label>
        <select class="f-input" asp-for="Birim">
          <option value="adet">Adet</option>
          <option value="kg">Kg</option>
          <option value="metre">Metre</option>
          <option value="litre">Litre</option>
          <option value="paket">Paket</option>
          <option value="kutu">Kutu</option>
          <option value="set">Set</option>
        </select>
      </div>
      <div class="f-group">
        <label class="f-label">Birim Fiyat *</label>
        <input class="f-input" asp-for="BirimFiyat" type="number" step="0.01" min="0" />
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem">
      <div class="f-group">
        <label class="f-label">Para Birimi</label>
        <select class="f-input" asp-for="ParaBirimi">
          <option value="TRY">TRY</option>
          <option value="USD">USD</option>
          <option value="EUR">EUR</option>
        </select>
      </div>
      <div class="f-group">
        <label class="f-label">Fatura No</label>
        <input class="f-input" asp-for="FaturaNo" placeholder="Fatura numarası" />
      </div>
      <div class="f-group">
        <label class="f-label">Tarih</label>
        <input class="f-input" asp-for="Tarih" type="date" />
      </div>
    </div>

    <div class="f-group">
      <label class="f-label">Açıklama</label>
      <textarea class="f-input" asp-for="Aciklama" rows="2" placeholder="Ek notlar"></textarea>
    </div>

    <div style="display:flex;gap:0.75rem;margin-top:1.5rem">
      <button type="submit" class="btn-primary">Tedarik Oluştur</button>
      <a class="btn-outline" href="/Tedarik">İptal</a>
    </div>
  </form>
</div>
