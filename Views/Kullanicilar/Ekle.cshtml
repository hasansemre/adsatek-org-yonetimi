@model UserCreateViewModel
@{ ViewData["Title"] = "Yeni Kullanıcı"; var departments = ViewBag.Departments as List<Department>; }

<div style="max-width:480px">
  <div class="section-header">
    <h2>Yeni Kullanıcı Ekle</h2>
    <a class="btn-outline" href="/Kullanicilar">Geri Dön</a>
  </div>

  <div asp-validation-summary="All" class="error-msg"></div>

  <div class="card">
    <form asp-action="Ekle" method="post">
      @Html.AntiForgeryToken()
      <div class="f-group">
        <label class="f-label">Ad Soyad</label>
        <input asp-for="FullName" class="f-input" placeholder="Ad Soyad" />
      </div>
      <div class="f-group">
        <label class="f-label">E-Posta</label>
        <input asp-for="Email" class="f-input" type="email" placeholder="ornek@sirket.com" />
      </div>
      <div class="f-group">
        <label class="f-label">Şifre</label>
        <input asp-for="Password" class="f-input" type="password" placeholder="En az 6 karakter" />
      </div>
      <div class="f-group">
        <label class="f-label">Rol</label>
        <select asp-for="Role" class="f-input">
          <option value="Admin">Admin</option>
          <option value="Yonetici">Yonetici</option>
          <option value="Calisan" selected>Calisan</option>
        </select>
      </div>
      <div class="f-group">
        <label class="f-label">Departman</label>
        <select asp-for="DepartmentId" class="f-input">
          <option value="">-- Seçiniz --</option>
          @if (departments != null)
          {
            @foreach (var d in departments)
            {
              <option value="@d.Id">@d.Ad</option>
            }
          }
        </select>
      </div>
      <button type="submit" class="btn-primary">Kullanıcı Oluştur</button>
    </form>
  </div>
</div>
