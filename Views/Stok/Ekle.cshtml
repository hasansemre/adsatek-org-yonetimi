@model OrgYonetimi.ViewModels.StokKartiViewModel
@{ ViewData["Title"] = "Yeni Stok Kartı"; }

<div class="section-header">
  <div>
    <h2>Yeni Stok Kartı</h2>
    <div class="section-sub">Ürün veya hizmet bilgilerini girin</div>
  </div>
  <a class="btn-outline" href="/Stok">← Geri Dön</a>
</div>

<div class="card" style="max-width:700px">
  <form method="post" asp-action="Ekle">
    @Html.AntiForgeryToken()

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
      <div class="f-group">
        <label class="f-label">Tip</label>
        <select class="f-input" asp-for="Tip">
          <option value="urun">Ürün</option>
          <option value="hizmet">Hizmet</option>
        </select>
      </div>
      <div class="f-group">
        <label class="f-label">Stok Kodu</label>
        <input class="f-input" asp-for="Kod" placeholder="SKU-001" />
      </div>
    </div>

    <div class="f-group">
      <label class="f-label">Ürün/Hizmet Adı *</label>
      <input class="f-input" asp-for="Ad" placeholder="Ürün veya hizmet adı" />
      <span asp-validation-for="Ad" style="color:var(--red);font-size:0.85rem"></span>
    </div>

    <div class="f-group">
      <label class="f-label">Açıklama</label>
      <textarea class="f-input" asp-for="Aciklama" rows="2" placeholder="Detaylı açıklama"></textarea>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem">
      <div class="f-group">
        <label class="f-label">Birim</label>
        <select class="f-input" asp-for="Birim">
          <option value="adet">Adet</option>
          <option value="kg">Kg</option>
          <option value="metre">Metre</option>
          <option value="litre">Litre</option>
          <option value="paket">Paket</option>
          <option value="kutu">Kutu</option>
          <option value="set">Set</option>
        </select>
      </div>
      <div class="f-group">
        <label class="f-label">Kategori</label>
        <input class="f-input" asp-for="Kategori" placeholder="ör: Elektronik" />
      </div>
      <div class="f-group">
        <label class="f-label">Min. Stok</label>
        <input class="f-input" asp-for="MinStok" type="number" step="1" min="0" />
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
      <div class="f-group">
        <label class="f-label">Birim Fiyat (Satış)</label>
        <input class="f-input" asp-for="BirimFiyat" type="number" step="0.01" />
      </div>
      <div class="f-group">
        <label class="f-label">Para Birimi</label>
        <select class="f-input" asp-for="ParaBirimi">
          <option value="TRY">TRY - Türk Lirası</option>
          <option value="USD">USD - Amerikan Doları</option>
          <option value="EUR">EUR - Euro</option>
        </select>
      </div>
    </div>

    <div style="display:flex;gap:0.75rem;margin-top:1.5rem">
      <button type="submit" class="btn-primary">Kaydet</button>
      <a class="btn-outline" href="/Stok">İptal</a>
    </div>
  </form>
</div>
