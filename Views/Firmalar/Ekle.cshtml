@model OrgYonetimi.ViewModels.FirmaViewModel
@{ ViewData["Title"] = "Yeni Firma"; }

<div class="section-header">
  <div>
    <h2>Yeni Firma Ekle</h2>
    <div class="section-sub">Temsilci veya tedarikçi firma bilgilerini girin</div>
  </div>
  <a class="btn-outline" href="/Firmalar">← Geri Dön</a>
</div>

<div class="card" style="max-width:700px">
  <form method="post" asp-action="Ekle">
    @Html.AntiForgeryToken()

    <div class="f-group">
      <label class="f-label">Firma Tipi</label>
      <select class="f-input" asp-for="Tip">
        <option value="tedarikci">Tedarikçi Firma</option>
        <option value="temsilci">Temsilci Firma</option>
      </select>
    </div>

    <div class="f-group">
      <label class="f-label">Firma Adı *</label>
      <input class="f-input" asp-for="Ad" placeholder="Firma adını girin" />
      <span asp-validation-for="Ad" style="color:var(--red);font-size:0.85rem"></span>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
      <div class="f-group">
        <label class="f-label">Yetkili Kişi</label>
        <input class="f-input" asp-for="YetkiliKisi" placeholder="Ad Soyad" />
      </div>
      <div class="f-group">
        <label class="f-label">Vergi No</label>
        <input class="f-input" asp-for="VergiNo" placeholder="Vergi numarası" />
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
      <div class="f-group">
        <label class="f-label">Telefon</label>
        <input class="f-input" asp-for="Telefon" placeholder="0(5XX) XXX XX XX" />
      </div>
      <div class="f-group">
        <label class="f-label">E-posta</label>
        <input class="f-input" asp-for="Email" type="email" placeholder="info@firma.com" />
      </div>
    </div>

    <div class="f-group">
      <label class="f-label">Adres</label>
      <textarea class="f-input" asp-for="Adres" rows="2" placeholder="Firma adresi"></textarea>
    </div>

    <div class="f-group">
      <label class="f-label">Açıklama</label>
      <textarea class="f-input" asp-for="Aciklama" rows="2" placeholder="Ek notlar"></textarea>
    </div>

    <div style="display:flex;gap:0.75rem;margin-top:1.5rem">
      <button type="submit" class="btn-primary">Kaydet</button>
      <a class="btn-outline" href="/Firmalar">İptal</a>
    </div>
  </form>
</div>
